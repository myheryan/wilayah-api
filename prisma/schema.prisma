// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Province {
  id    Int    @id
  name  String
  cities City[]
}

model City {
  id         Int      @id
  name       String
  provinceId Int
  province   Province @relation(fields: [provinceId], references: [id])
  districts  District[]
}

model District {
  id              Int           @id
  name            String
  cityId          Int
  city            City          @relation(fields: [cityId], references: [id])
  subDistricts    SubDistrict[]
  
  // Data Lion Parcel nempel di Kecamatan (District)
  lionDistrictId  String?       @map("lion_district_id")
  threeLetterCode String?       @map("three_letter_code")
}

model SubDistrict {
  id          Int      @id
  name        String
  postalCode  String   @map("postal_code")
  districtId  Int
  district    District @relation(fields: [districtId], references: [id])
  
  // Tetap simpan fullLabel untuk autocomplete Shopee-style yang cepat
  fullLabel   String   @unique @map("full_label")
}